@model A_Mover_Desktop_Final.Models.OrdemProducao

@{
    ViewData["Title"] = "Eliminar Ordem de Produção";
    ViewData["ActiveMenu"] = "OrdensProducao";
}

<div class="col-xxl">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h1 class="mb-0">Eliminar Ordem de Produção</h1>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <i class="bx bx-error-circle me-2"></i>
                Tem a certeza de que pretende eliminar esta ordem de produção?
            </div>

            <!-- Encomenda -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.IDEncomenda)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.IDEncomenda)
                    </p>
                </div>
            </div>

            <!-- Número da Ordem -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.NumeroOrdem)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.NumeroOrdem)
                    </p>
                </div>
            </div>

            <!-- Estado -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.Estado)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.Estado)
                    </p>
                </div>
            </div>

            <!-- País de Destino -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.PaisDestino)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.PaisDestino)
                    </p>
                </div>
            </div>

            <!-- Data de Criação -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.DataCriacao)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.DataCriacao)
                    </p>
                </div>
            </div>

            <!-- Data de Conclusão -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.DataConclusao)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.DataConclusao)
                    </p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IDOrdemProducao" />

                <div class="row">
                    <div class="col-sm-10 offset-sm-2">
                        <button type="submit" class="btn btn-danger me-2">
                            <i class="bx bx-trash me-1"></i> Eliminar
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bx bx-arrow-back me-1"></i> Voltar
                        </a>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>