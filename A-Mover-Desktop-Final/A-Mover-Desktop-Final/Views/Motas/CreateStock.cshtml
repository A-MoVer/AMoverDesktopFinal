@model A_Mover_Desktop_Final.Models.Mota

@{
    ViewData["Title"] = "Registar Mota em Stock";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 m-0">
                <i class="bx bx-plus-circle text-primary me-2"></i>
                Registar Mota em Stock
            </h1>
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="bx bx-arrow-back me-1"></i>Voltar
            </a>
        </div>

        <form asp-action="CreateStock" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row">
                <div class="col-12 col-lg-8">
                    <div class="card bg-light mb-3">
                        <div class="card-header bg-transparent">
                            <h5 class="mb-0">
                                <i class="bx bx-info-circle me-2"></i>
                                Dados da Mota
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="IDModelo" class="form-label">Modelo</label>
                                <select asp-for="IDModelo" class="form-select" asp-items="ViewBag.IDModelo"></select>
                                <span asp-validation-for="IDModelo" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NumeroIdentificacao" class="form-label">Nº Identificação</label>
                                <input asp-for="NumeroIdentificacao" class="form-control" />
                                <span asp-validation-for="NumeroIdentificacao" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Cor" class="form-label"></label>
                                <input asp-for="Cor" class="form-control" />
                                <span asp-validation-for="Cor" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Quilometragem" class="form-label"></label>
                                <input asp-for="Quilometragem" class="form-control" type="number" min="0" step="0.1" />
                                <span asp-validation-for="Quilometragem" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="alert alert-info small">
                        <i class="bx bx-info-circle me-1"></i>
                        As motas registadas aqui ficam automaticamente com estado <strong>Ativo</strong> e sem ordem de produção.
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bx bx-x me-1"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bx bx-save me-1"></i>Registar em Stock
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
