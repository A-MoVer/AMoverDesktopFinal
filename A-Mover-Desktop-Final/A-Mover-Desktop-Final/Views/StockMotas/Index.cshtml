@model IEnumerable<A_Mover_Desktop_Final.Models.StockMota>

@{
    ViewData["Title"] = "Stock de Motas";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 m-0">
                <i class="bx bx-cycling text-primary me-2"></i>
                Stock de Motas
            </h1>
            <div class="d-flex gap-2">
                <a class="btn btn-primary btn-sm" asp-action="Create">
                    <i class="bx bx-plus me-1"></i>Adicionar Stock
                </a>
                <a class="btn btn-success btn-sm" asp-action="Vender">
                    <i class="bx bx-cart me-1"></i>Vender Mota
                </a>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover mb-0" id="tabelaStockMotas">
                <thead class="table-light">
                    <tr>
                        <th>Modelo</th>
                        <th class="text-center">Quantidade</th>
                        <th class="d-none d-md-table-cell">Atualizado</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.ModeloMota?.Nome</strong></td>
                            <td class="text-center">
                                <span class="badge bg-primary">@item.QuantidadeDisponivel</span>
                            </td>
                            <td class="d-none d-md-table-cell">@item.DataAtualizacao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="Vender" asp-route-id="@item.IDModelo" class="btn btn-sm btn-success text-white">
                                    <i class="bx bx-cart"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tabelaStockMotas').DataTable({
                "pageLength": 10,
                "responsive": true,
                "order": [[1, "desc"]],
                "language": {
                    "lengthMenu": "Mostrar _MENU_ registos por página",
                    "paginate": {
                        "first": "Primeira",
                        "last": "Última",
                        "next": "Próxima",
                        "previous": "Anterior"
                    },
                    "info": "_START_ a _END_ de _TOTAL_ registos",
                    "infoEmpty": "Nenhum registo disponível",
                    "search": "Pesquisar:",
                    "zeroRecords": "Nenhum registro encontrado",
                    "infoFiltered": "(filtrado de _MAX_ registos no total)"
                },
                "dom": "<'row'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>
}
