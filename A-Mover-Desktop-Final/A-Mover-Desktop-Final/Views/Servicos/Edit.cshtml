@model A_Mover_Desktop_Final.Models.Servico

@{
    ViewData["Title"] = "Editar Intervenção";
    var tipos = ViewData["TiposServico"] as List<TipoServico> ?? new List<TipoServico>();
    var estados = ViewData["EstadosServico"] as List<EstadoServico> ?? new List<EstadoServico>();
}

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 m-0">
                <i class="bx bx-edit text-warning me-2"></i>
                Editar Intervenção
            </h1>
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="bx bx-arrow-back me-1"></i>Voltar
            </a>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="IDServico" />

            <div class="row">
                <div class="col-12 col-lg-8">
                    <div class="card bg-light mb-3">
                        <div class="card-header bg-transparent">
                            <h5 class="mb-0">
                                <i class="bx bx-info-circle me-2"></i>
                                Dados da Intervenção
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label asp-for="IDMota" class="form-label"></label>
                                <select asp-for="IDMota" class="form-select" asp-items="ViewBag.IDMota"></select>
                                <span asp-validation-for="IDMota" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Tipo" class="form-label"></label>
                                <select asp-for="Tipo" class="form-select">
                                    @foreach (var tipo in tipos)
                                    {
                                        <option value="@tipo" selected="@(Model.Tipo == tipo)">@tipo</option>
                                    }
                                </select>
                                <span asp-validation-for="Tipo" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Descricao" class="form-label"></label>
                                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Descricao" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Estado" class="form-label"></label>
                                <select asp-for="Estado" class="form-select">
                                    @foreach (var estado in estados)
                                    {
                                        <option value="@estado" selected="@(Model.Estado == estado)">@estado</option>
                                    }
                                </select>
                                <span asp-validation-for="Estado" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DataServico" class="form-label"></label>
                                <input asp-for="DataServico" class="form-control" type="datetime-local" />
                                <span asp-validation-for="DataServico" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DataConclusao" class="form-label"></label>
                                <input asp-for="DataConclusao" class="form-control" type="datetime-local" />
                                <span asp-validation-for="DataConclusao" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="alert alert-info small">
                        <i class="bx bx-info-circle me-1"></i>
                        Ajuste o tipo e o estado conforme necessário antes de guardar.
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bx bx-x me-1"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bx bx-save me-1"></i>Guardar Alterações
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
