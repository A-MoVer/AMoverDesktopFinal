鬠ｿ@model A_Mover_Desktop_Final.Models.Servico

@{
    ViewData["Title"] = "Gerenciar Peﾃδｧas da Intervenﾃδｧﾃδ｣o";
}

<div class="card  p-4">
    <h2 class="text-primary mb-4">
        <i class="bi bi-wrench"></i> Gestﾃδ｣o de Peﾃδｧas - Intervenﾃδｧﾃδ｣o #@Model.IDServico
    </h2>
    
    <div class="alert alert-info">
        <h5><i class="bi bi-info-circle"></i> Informaﾃδｧﾃδｵes da Mota</h5>
        <p><strong>Nﾃつｺ Identificaﾃδｧﾃδ｣o:</strong> @Model.Mota?.NumeroIdentificacao</p>
        <p><strong>Modelo:</strong> @Model.Mota?.ModeloMota?.Nome</p>
        <p><strong>Tipo de Serviﾃδｧo:</strong> @Model.Tipo</p>
    </div>
    
    <form asp-action="GerirPecas" method="post">
        <input type="hidden" name="id" value="@Model.IDServico" />
        
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Substituir</th>
                        <th>Part Number</th>
                        <th>Descriﾃδｧﾃδ｣o</th>
                        <th>Nﾃつｺ de Sﾃδｩrie Atual</th>
                        <th>Novo Nﾃつｺ de Sﾃδｩrie</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Mota?.MotasPecasSN != null)
                    {
                        foreach (var peca in Model.Mota.MotasPecasSN)
                        {
                            var pecaAlterada = Model.PecasAlteradas?.FirstOrDefault(p => p.IDMotasPecasSN == peca.IDMotasPecasSN);
                            var isChecked = pecaAlterada != null;
                            
                            <tr>
                                <td>
                                    <div class="form-check">
                                        <input class="form-check-input peca-checkbox" type="checkbox" 
                                               name="pecasParaSubstituir" value="@peca.IDMotasPecasSN"
                                               id="peca_@peca.IDMotasPecasSN" @(isChecked ? "checked" : "")>
                                    </div>
                                </td>
                                <td>@peca.Pecas?.PartNumber</td>
                                <td>@peca.Pecas?.Descricao</td>
                                <td>@peca.NumeroSerie</td>
                                <td>
                                    <input type="text" class="form-control peca-serie"
                                           name="novasSeriesNumericas"
                                           id="serie_@peca.IDMotasPecasSN"
                                           placeholder="Novo nﾃδｺmero de sﾃδｩrie"
                                           @(isChecked ? "" : "disabled")>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">
                                <em>Esta mota nﾃδ｣o possui peﾃδｧas registradas com nﾃδｺmero de sﾃδｩrie.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
<!-- Seﾃδｧﾃδ｣o de Notas da Manutenﾃδｧﾃδ｣o -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-journal-text"></i> Notas da Manutenﾃδｧﾃδ｣o</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Observaﾃδｧﾃδｵes Tﾃδｩcnicas</label>
            <textarea class="form-control" name="NotasManutencao" rows="3" 
                      placeholder="Registre detalhes importantes sobre a manutenﾃδｧﾃδ｣o realizada...">@Model.NotasServico</textarea>
            <small class="text-muted">
                Inclua informaﾃδｧﾃδｵes relevantes como: anomalias detectadas, recomendaﾃδｧﾃδｵes 
                para o cliente ou observaﾃδｧﾃδｵes para a prﾃδｳxima manutenﾃδｧﾃδ｣o.
            </small>
        </div>
    </div>
</div>
        <div class="d-flex justify-content-between mt-4">
            <div>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Salvar Alteraﾃδｧﾃδｵes
                </button>
                <a asp-action="Details" asp-route-id="@Model.IDServico" class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
            
            <div>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalConcluirServico">
                    <i class="bi bi-check-circle"></i> Concluir Serviﾃδｧo
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Modal para confirmar conclusﾃδ｣o do serviﾃδｧo -->
<div class="modal fade" id="modalConcluirServico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Concluir Serviﾃδｧo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja concluir este serviﾃδｧo?</p>
                <p>Esta aﾃδｧﾃδ｣o nﾃδ｣o pode ser desfeita.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-action="ConcluirServico" asp-route-id="@Model.IDServico" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">Concluir Serviﾃδｧo</button>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function() {
            // Ativar/desativar campo de serial conforme checkbox
            $('.peca-checkbox').change(function() {
                var id = $(this).attr('id').replace('peca_', 'serie_');
                if ($(this).is(':checked')) {
                    $('#' + id).prop('disabled', false);
                } else {
                    $('#' + id).prop('disabled', true);
                    $('#' + id).val('');
                }
            });
        });
    </script>
}
