@model A_Mover_Desktop_Final.Models.Cliente

@{
    ViewData["Title"] = "Criar Novo Cliente";
}

<div class="col-xxl">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h1 class="mb-0">Criar Novo Cliente</h1>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Nome -->
                <div class="row mb-3">
                    <label asp-for="Nome" class="col-sm-2 col-form-label">
                        Nome <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>
                </div>

                <!-- Tipo -->
                <div class="row mb-3">
                    <label asp-for="Tipo" class="col-sm-2 col-form-label">
                        Tipo <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <select asp-for="Tipo"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<TipoCliente>()">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="Tipo" class="text-danger"></span>
                    </div>
                </div>

                <!-- Número Cliente -->
                <div class="row mb-3">
                    <label asp-for="NumeroCliente" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="NumeroCliente" class="form-control" />
                        <span asp-validation-for="NumeroCliente" class="text-danger"></span>
                    </div>
                </div>

                <!-- País -->
                <div class="row mb-3">
                    <label asp-for="Pais" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="Pais" class="form-control" />
                        <span asp-validation-for="Pais" class="text-danger"></span>
                    </div>
                </div>

                <!-- País de Origem -->
                <div class="row mb-3">
                    <label asp-for="PaisOrigem" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <input asp-for="PaisOrigem" class="form-control" />
                        <span asp-validation-for="PaisOrigem" class="text-danger"></span>
                    </div>
                </div>

                <!-- Estado -->
                <div class="row mb-3">
                    <label asp-for="Estado" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <select asp-for="Estado"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<EstadoCliente>()">
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>
                </div>

                <p class="text-muted">
                    <span class="text-danger">*</span> - Preenchimento obrigatório
                </p>

                <div class="row justify-content-start">
                    <div class="col-sm-10 offset-sm-2 d-flex">
                        <input type="submit" value="Criar" class="btn btn-primary me-2" />
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    </div>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}