@model A_Mover_Desktop_Final.Models.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="col-xxl">
    <div class="card">

        <div class="card-header">
            <h1 class="mb-0 text-danger">Eliminar Cliente</h1>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Tem a certeza que pretende eliminar este cliente?
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">Nome</label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">@Model.Nome</p>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">Tipo</label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">@Model.Tipo</p>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">Estado</label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">@Model.Estado</p>
                </div>
            </div>

            <form asp-action="Delete">

                <input type="hidden" asp-for="IDCliente" />

                <button type="submit" class="btn btn-danger me-2">
                    Eliminar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>
    </div>
</div>