@model A_Mover_Desktop_Final.Models.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
    ViewData["ActiveMenu"] = "Clientes";
}

<div class="col-xxl">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h1 class="mb-0">Eliminar Cliente</h1>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <i class="bx bx-error-circle me-2"></i>
                Tem a certeza de que pretende eliminar este cliente?
            </div>

            <!-- Nome -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.Nome)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.Nome)
                    </p>
                </div>
            </div>

            <!-- Tipo -->
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label fw-bold">
                    @Html.DisplayNameFor(model => model.Tipo)
                </label>
                <div class="col-sm-10">
                    <p class="form-control-plaintext">
                        @Html.DisplayFor(model => model.Tipo)
                    </p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IDCliente" />

                <div class="row">
                    <div class="col-sm-10 offset-sm-2">
                        <button type="submit" class="btn btn-danger me-2">
                            <i class="bx bx-trash me-1"></i> Eliminar
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bx bx-arrow-back me-1"></i> Voltar
                        </a>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>