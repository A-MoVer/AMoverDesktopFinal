@model A_Mover_Desktop_Final.Models.Compras

@{
    ViewData["Title"] = "Criar Nova Compra";
    ViewData["ActiveMenu"] = "Compras";
}

<div class="col-xxl">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h1 class="mb-0">Criar Nova Compra</h1>
        </div>

        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Peça -->
                <div class="row mb-3">
                    <label asp-for="PecaId" class="col-sm-2 col-form-label">
                        Peça <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <select asp-for="PecaId" class="form-select" asp-items="ViewBag.PecaId">
                            <option value="">-- Selecione uma Peça --</option>
                        </select>
                        <span asp-validation-for="PecaId" class="text-danger"></span>
                    </div>
                </div>

                <!-- Data do Pedido -->
                <div class="row mb-3">
                    <label asp-for="DataPedido" class="col-sm-2 col-form-label">
                        Data do Pedido <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <div class="input-group input-group-merge">
                            <span class="input-group-text">
                                <i class="bx bx-calendar"></i>
                            </span>
                            <input asp-for="DataPedido" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="DataPedido" class="text-danger"></span>
                    </div>
                </div>

                <!-- Fornecedor -->
                <div class="row mb-3">
                    <label asp-for="FornecedorId" class="col-sm-2 col-form-label">
                        Fornecedor <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <select asp-for="FornecedorId" class="form-select" asp-items="ViewBag.FornecedorId">
                            <option value="">-- Selecione um Fornecedor --</option>
                        </select>
                        <span asp-validation-for="FornecedorId" class="text-danger"></span>
                    </div>
                </div>

                <!-- Quantidade -->
                <div class="row mb-3">
                    <label asp-for="Quantidade" class="col-sm-2 col-form-label">
                        Quantidade <span class="text-danger">*</span>
                    </label>
                    <div class="col-sm-10">
                        <input asp-for="Quantidade" class="form-control" min="1" />
                        <span asp-validation-for="Quantidade" class="text-danger"></span>
                    </div>
                </div>

                <p class="text-muted">
                    <span class="text-danger">*</span> - Preenchimento obrigatório
                </p>

                <div class="row justify-content-start">
                    <div class="col-sm-10 offset-sm-2">
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="bx bx-save me-1"></i> Criar
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bx bx-arrow-back me-1"></i> Voltar
                        </a>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}