@model IEnumerable<A_Mover_Desktop_Final.Models.Pecas>

@{
    ViewData["Title"] = "Gestão de Peças";
}

<div class="card m-5 p-1">
    <div class="d-flex justify-content-between align-items-center m-3">
        <div>
            <h1 class="m-0">Gestão de Peças</h1>
            <div class="text-danger fw-bold mt-1"><i class="bx bx-error-circle ps-1"></i> Nota: Só é para adicionar as peças importantes.</div>
        </div>
        <a type="button" class="btn btn-primary" asp-action="Create">Adicionar Peça</a>
    </div>

    <!-- Alertas de Sucesso/Erro -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
            <i class="bx bx-error-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive text-nowrap">
        <table class="table" id="tabela">
            <thead class="table-light">
                <tr>
                    <th>Part Number</th>
                    <th>Descrição</th>
                    <th>Fornecedor</th>
                    <th>Quantidade</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var peca in Model)
                {
                    <tr id="row-@peca.IDPeca">
                        <td><b>@Html.DisplayFor(modelItem => peca.PartNumber)</b></td>
                        <td>@Html.DisplayFor(modelItem => peca.Descricao)</td>
                        <td>@peca.Fornecedor?.Nome</td>
                        <td>
                            @{
                                var quantidades = ViewBag.Quantidades as Dictionary<int, int>;
                                int qtd = quantidades != null && quantidades.ContainsKey(peca.IDPeca) ? quantidades[peca.IDPeca] : 0;
                            }
                            <span class="badge bg-@(qtd > 0 ? "success" : "danger")" style="font-size: 0.9em;">
                                @qtd un
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@peca.IDPeca" class="btn btn-sm btn-warning text-white me-2">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@peca.IDPeca" class="btn btn-sm btn-danger text-white">
                                <i class="fas fa-trash-alt"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tabela').DataTable({
                "pageLength": 10,
                "language": {
                    "lengthMenu": "Mostrar _MENU_ registos por página",
                    "paginate": {
                        "first": "Primeira",
                        "last": "Última",
                        "next": "Próxima",
                        "previous": "Anterior"
                    },
                    "info": "_START_ a _END_ de _TOTAL_ registos",
                    "infoEmpty": "Nenhum registo disponível",
                    "search": "Pesquisar:",
                    "zeroRecords": "Nenhum registro encontrado"
                }
            });
        });
    </script>
}
