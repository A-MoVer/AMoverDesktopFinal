pipeline {
    agent any // Usa o ambiente do infra01 para evitar problemas com Docker

    environment {
        // Definição dos destinatários
        RECIPIENTS = "diogooresende@utad.pt, dianamc@utad.pt"
        // Caminho para a solução (ajustado para a tua estrutura de pastas)
        SLN_PATH = "A-Mover-Desktop-Final/A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln"
    }

    stages {
        stage('Checkout Código') {
            steps {
                // Saca o código mais recente do GitHub
                checkout scm
            }
        }

        // ==========================================================
        // 🧪 PASSO 1: EXECUÇÃO DE TESTES E GERAÇÃO DE RELATÓRIO
        // ==========================================================
        stage('Executar Testes de Validação') {
            steps {
                echo '🚀 A iniciar os testes automatizados da Diana...'
                
                // O comando corre os testes e o "2>&1 | tee" grava TUDO (erros e sucessos) no log
                // Adicionámos o logger normal para o relatório ser mais legível no email
                sh "dotnet test ${env.SLN_PATH} --configuration Release --logger 'console;verbosity=normal' 2>&1 | tee test_result.log"
            }
        }

        // ==========================================================
        // 🚀 PASSO 2: DEPLOY EM PRE-PROD (SÓ SE O PASSO 1 PASSAR)
        // ==========================================================
        stage('Deploy to PRE-PROD') {
            steps {
                echo '✅ Todos os testes passaram! A atualizar o ambiente de Pre-Prod...'
                
                // Aplica os YAMLs e força o Kubernetes a atualizar a imagem para a mais recente
                sh "kubectl apply -f /home/diogo_admin/lcm-k8s/preprod/ -n lcm-preprod"
                sh "kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod"
            }
        }
    }

    // ==========================================================
    // 📢 NOTIFICAÇÕES E REPORTS (A PARTE QUE A DIANA RECEBE)
    // ==========================================================
    post {
        success {
            echo '📧 A enviar email de sucesso...'
            mail to: "${env.RECIPIENTS}",
                 subject: "✅ Jenkins: Pipeline Sucesso - Versão Estável em Pre-Prod",
                 body: """Olá Diana e Diogo,\n\n
Boas notícias! O pipeline foi concluído com sucesso.\n
Os testes automatizados passaram em todos os cenários e o ambiente de Pre-Produção foi atualizado.\n\n
🔗 Aceder ao sistema: http://lcm-preprod.amover\n\n
Cumprimentos,\n
O vosso Servidor Jenkins (infra01)"""
        }
        
        failure {
            echo '📧 A preparar o relatório de erro detalhado para a Diana...'
            script {
                // Tentamos ler o ficheiro de log que criámos no passo dos testes
                def reportContent = "Infelizmente, não foi possível extrair o log de erro. Verifica a consola do Jenkins."
                
                if (fileExists('test_result.log')) {
                    reportContent = readFile('test_result.log')
                    // Se o log for gigante (mais de 10.000 carateres), cortamos para o email não ser rejeitado
                    if (reportContent.length() > 8000) {
                        reportContent = "--- LOG MUITO EXTENSO (A mostrar o final) ---\n\n" + 
                                        reportContent.substring(reportContent.length() - 8000)
                    }
                }
                
                mail to: "${env.RECIPIENTS}",
                     subject: "❌ Jenkins: FALHA no Pipeline (Deploy Abortado)",
                     body: """Olá Diana,\n\n
Ocorreu um erro durante a execução dos testes automatizados. O deploy para Pre-Prod foi bloqueado para evitar quebras no sistema.\n\n
------------------------------------------------------------
📋 RELATÓRIO DETALHADO DE ERRO (.NET SDK):
------------------------------------------------------------
${reportContent}
------------------------------------------------------------\n\n
Diana, por favor analisa as mensagens acima. Geralmente, o erro está indicado nas últimas linhas (Failed!).\n
Depois de corrigires, basta fazeres um novo Push para a 'main'.\n\n
Cumprimentos,\n
O vosso Servidor Jenkins """
            }
        }
    }
}
