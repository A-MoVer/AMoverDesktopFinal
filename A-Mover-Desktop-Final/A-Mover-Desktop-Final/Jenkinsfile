pipeline {
    agent any

    // 🛠️ Esta parte resolve o erro "dotnet: not found"
    tools {
        dotnetsdk 'dotnet8' 
    }

    environment {
        RECIPIENTS = "diogooresende@utad.pt, dianamc@utad.pt"
    }

    stages {
        stage('Checkout Código') {
            steps {
                checkout scm
            }
        }

        stage('Executar Testes de Validação') {
            steps {
                echo '🚀 A iniciar os testes automatizados da Diana...'
                // Agora o comando sh já vai encontrar o dotnet que o Jenkins instalou
                sh 'dotnet test A-Mover-Desktop-Final/A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln --configuration Release 2>&1 | tee test_result.log'
            }
        }

        stage('Deploy to PRE-PROD') {
            steps {
                echo '✅ Testes passados! A atualizar o Kubernetes...'
                
                // 🔑 Esta parte resolve o erro "kubectl: not found" e a falta de permissão
                // Precisas de ter o plugin "Kubernetes CLI" instalado no Jenkins
                withKubeConfig([credentialsId: 'kubeconfig-preprod']) {
                    // ATENÇÃO: Garante que os ficheiros YAML estão no teu GitHub na pasta k8s/preprod/
                    sh "kubectl apply -f k8s/preprod/ -n lcm-preprod"
                    sh "kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod"
                }
            }
        }
    }

    post {
        success {
            mail to: "${env.RECIPIENTS}",
                 subject: "✅ Jenkins: Pipeline Sucesso - Pre-Prod Atualizado",
                 body: "Olá Diana e Diogo,\n\nOs testes passaram e o ambiente de Pre-Prod foi atualizado!\n\nLink: http://lcm-preprod.amover"
        }
        failure {
            script {
                def testLog = fileExists('test_result.log') ? readFile('test_result.log') : "Erro de ambiente: O dotnet não foi encontrado ou o Jenkins não conseguiu iniciar."
                if (testLog.length() > 5000) testLog = testLog.substring(testLog.length() - 5000)
                
                mail to: "${env.RECIPIENTS}",
                     subject: "❌ Jenkins: FALHA no Pipeline!",
                     body: "Olá Diana,\n\nOcorreu um erro no pipeline. O deploy foi bloqueado.\n\nLOG DE ERRO:\n${testLog}"
            }
        }
    }
}
