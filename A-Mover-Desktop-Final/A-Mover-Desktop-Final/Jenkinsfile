pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/dotnet/sdk:8.0'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        RECIPIENTS = "diogooresende@utad.pt, dianamc@utad.pt"
    }

    stages {
        stage('Checkout Código') {
            steps {
                checkout scm
            }
        }

        // ==========================================
        // 🧪 PASSO 1: TESTES ISOLADOS (E GRAVAÇÃO DE LOGS)
        // ==========================================
        stage('Executar Testes de Validação') {
            steps {
                echo '🚀 A iniciar os testes automatizados dentro do contentor .NET 8...'
                
                // Executa os testes e guarda todo o output num ficheiro chamado "test_result.log"
                // O "tee" garante que o log aparece no ecrã do Jenkins E é gravado no ficheiro
                sh 'dotnet test A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln --configuration Release 2>&1 | tee test_result.log'
            }
        }

        // ==========================================
        // 🚀 PASSO 2: DEPLOY EM PRE-PROD (SÓ SE PASSAR!)
        // ==========================================
        stage('Deploy to PRE-PROD') {
            steps {
                echo '✅ Todos os testes passaram! A atualizar o Pre-Prod...'
                sh "kubectl apply -f /home/diogo_admin/lcm-k8s/preprod/ -n lcm-preprod"
                sh "kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod"
            }
        }
    }

    // ==========================================
    // 📢 ENVIAR EMAILS AUTOMÁTICOS COM OS ERROS
    // ==========================================
    post {
        success {
            echo '📧 A enviar email de sucesso...'
            mail to: "${env.RECIPIENTS}",
                 subject: "✅ Jenkins: Pipeline Sucesso - Versão estável em Pre-Prod",
                 body: """Olá Diana,\n\n
O pipeline foi executado com sucesso!\n
Os testes automatizados passaram em todos os cenários (validados isoladamente em contentor Kubernetes) e a nova versão já se encontra disponível no ambiente de Pre-Produção.\n\n
Aceder ao ambiente: http://lcm-preprod.amover\n\n
Cumprimentos,\n
"""
        }
        
        failure {
            echo '📧 A ler ficheiro de erros e a enviar email...'
            
            // Script em Groovy para ler as últimas 30 linhas do log de erro para enviar no email
            script {
                def testLog = "Não foi possível carregar o log de testes."
                if (fileExists('test_result.log')) {
                    testLog = readFile('test_result.log')
                    // Limita o tamanho do log no email para não ficar gigante (ex: últimas 5000 letras)
                    if (testLog.length() > 5000) {
                        testLog = testLog.substring(testLog.length() - 5000)
                    }
                }
                
                mail to: "${env.RECIPIENTS}",
                     subject: "❌ Jenkins: ALERTA de Falha no Pipeline!",
                     body: """Olá ,\n\n
ATENÇÃO: Os testes automatizados da Diana FALHARAM no ambiente de testes do cluster.\n
Por razões de segurança, o deploy para o ambiente de Pre-Produção (PRE-PROD) foi ABORTADO.\n\n
--------------------------------------------------
📋 EXTRATO DO LOG DE ERRO DOS TESTES (.NET):
--------------------------------------------------
${testLog}
--------------------------------------------------\n\n
Por favor, Diana, corrige os erros indicados acima e faz um novo push para o GitHub para reiniciar a validação.\n\n
Cumprimentos,\n
O Servidor Jenkins """
            }
        }
    }
}
