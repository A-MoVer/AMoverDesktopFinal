pipeline {
    agent any

    tools {
        dotnetsdk 'dotnet8'
    }

    environment {
        RECIPIENTS = "diogooresende@utad.pt, dianamc@utad.pt"
        KUBECONFIG_ID = 'kubeconfig-preprod'
        SLN_PATH = 'A-Mover-Desktop-Final/A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln'
        
        // 🚀 SOLUÇÃO PARA O ERRO ICU (TESTES DA DIANA)
        DOTNET_SYSTEM_GLOBALIZATION_INVARIANT = 'true'
    }

    stages {
        stage('Checkout Código') {
            steps {
                checkout scm
            }
        }

        stage('Executar Testes de Validação') {
            steps {
                echo '🚀 A iniciar os testes automatizados da Diana...'
                // O 2>&1 | tee garante que o erro vai para o log e para o e-mail
                sh "dotnet test ${env.SLN_PATH} --configuration Release 2>&1 | tee test_result.log"
            }
        }

        stage('Deploy to PRE-PROD') {
            steps {
                echo '✅ Testes passados! A preparar deploy...'
                
                withKubeConfig([credentialsId: "${env.KUBECONFIG_ID}"]) {
                    script {
                        // 🛠️ SOLUÇÃO PARA O KUBECTL NOT FOUND
                        // Se o kubectl não existir no container, vamos buscá-lo
                        sh """
                            if ! command -v kubectl &> /dev/null; then
                                echo 'Instalando kubectl temporariamente...'
                                curl -LO "https://dl.k8s.io/release/\$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                                chmod +x ./kubectl
                                ./kubectl apply -f k8s/preprod/ -n lcm-preprod
                                ./kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod
                            else
                                kubectl apply -f k8s/preprod/ -n lcm-preprod
                                kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod
                            fi
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            mail to: "${env.RECIPIENTS}",
                 subject: "✅ Jenkins: Pipeline Sucesso - Pre-Prod Atualizado",
                 body: "Olá Diana e Diogo,\n\nOs testes passaram e o ambiente de Pre-Prod foi atualizado!\n\nLink: http://lcm-preprod.amover"
        }
        failure {
            script {
                def testLog = "Ocorreu um erro de ambiente ou de sistema."
                if (fileExists('test_result.log')) {
                    testLog = readFile('test_result.log')
                    if (testLog.length() > 5000) testLog = testLog.substring(testLog.length() - 5000)
                }
                
                mail to: "${env.RECIPIENTS}",
                     subject: "❌ Jenkins: FALHA no Pipeline!",
                     body: "Olá Diana,\n\nOs testes falharam. Detalhes abaixo:\n\n📋 LOG DE ERRO:\n${testLog}"
            }
        }
    }
}
