pipeline {
    agent any

    environment {
        REGISTRY   = 'ghcr.io'
        IMAGE_NAME = 'ghcr.io/a-mover/amoverdesktopfinal'
    }

    stages {
        stage('Deploy to Kubernetes (Dev)') {
            steps {
                script {
                    // O Jenkins apenas diz ao K8s para atualizar a imagem para a versão mais recente compilada pelo GitHub
                    sh "kubectl set image deployment/lcm-app-deployment lcm-app=${IMAGE_NAME}:latest -n lcm-dev"
                    
                    // Força o Kubernetes a fazer o rollout (reiniciar os pods com a nova imagem do registo)
                    sh "kubectl rollout restart deployment/lcm-app-deployment -n lcm-dev"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
