pipeline {
    agent any

    environment {
        REGISTRY   = 'ghcr.io'
        IMAGE_NAME = 'ghcr.io/a-mover/amoverdesktopfinal'
    }

    stages {
        stage('Deploy to Kubernetes (Dev)') {
            steps {
                script {
                    // 1. Saca o kubectl para dentro da pasta temporária da pipeline
                    sh "curl -LO https://dl.k8s.io/release/v1.30.0/bin/linux/amd64/kubectl"
                    sh "chmod +x ./kubectl"
                    
                    // 2. Executa os comandos usando o kubectl que acabámos de descarregar
                    sh "./kubectl set image deployment/lcm-app-deployment lcm-app=${IMAGE_NAME}:latest -n lcm-dev"
                    sh "./kubectl rollout restart deployment/lcm-app-deployment -n lcm-dev"
                }
            }
        }
    }

    post {
        always {
            // Limpa tudo (incluindo o kubectl temporário)
            cleanWs()
        }
    }
}
