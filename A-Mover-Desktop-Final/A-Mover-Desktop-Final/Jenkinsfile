pipeline {
    agent any

    tools {
        dotnetsdk 'dotnet8'
    }

    environment {
        // --- GRUPOS DE E-MAIL ---
        TEAM_EMAILS = "diogooresende@utad.pt, dianamc@utad.pt"
        CHIEFS_EMAILS = "ars@utad.pt, jgouveia@utad.pt, diogooresende@utad.pt" //

        // --- CONFIGURAÇÕES GERAIS ---
        SLN_PATH = 'A-Mover-Desktop-Final/A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln'
        IMAGE_NAME = 'ghcr.io/a-mover/amoverdesktopfinal:latest'
        DOTNET_SYSTEM_GLOBALIZATION_INVARIANT = 'true'

        // --- PRE-PROD (CLUSTER) ---
        KUBECONFIG_ID = 'kubeconfig-preprod'

        // --- PRODUÇÃO (VPS EXTERNA) ---
        VPS_IP = '85.234.145.56'
        VPS_USER = 'root'
        VPS_CRED_ID = 'vps-producao'
    }

    stages {
        stage('Checkout e Testes') {
            steps {
                checkout scm
                echo '🚀 Validando código da Diana...'
                sh "dotnet test ${env.SLN_PATH} --configuration Release 2>&1 | tee test_result.log"
            }
        }

        stage('Deploy para PRE-PROD') {
            steps {
                echo '✅ Testes passados. Atualizando Pre-Prod local...'
                withKubeConfig([credentialsId: "${env.KUBECONFIG_ID}"]) {
                    script {
                        sh "./kubectl apply -f k8s/preprod/ -n lcm-preprod"
                        sh "./kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod"
                    }
                }
                mail to: "${env.TEAM_EMAILS}", 
                     subject: "🛠️ Pre-Prod Atualizado", 
                     body: "Diana, valida em http://lcm-preprod.amover antes da aprovação final."
            }
        }

        stage('Aprovação dos Chefes') {
            steps {
                script {
                    mail to: "${env.CHIEFS_EMAILS}",
                         subject: "🚀 Autorização: Publicação em Produção (VPS)",
                         body: "A versão de Pre-Prod foi validada. Autoriza o deploy para a VPS?\n${env.BUILD_URL}input/"
                    
                    input message: "Publicar na VPS de Produção (85.234.145.56)?", ok: "Sim, Publicar!"
                }
            }
        }

        stage('Deploy para PRODUÇÃO (VPS)') {
            steps {
                echo "🚀 Conectando à VPS ${env.VPS_IP}..."
                sshagent([env.VPS_CRED_ID]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${env.VPS_USER}@${env.VPS_IP} << 'EOF'
                            # 1. Atualizar Imagem
                            docker pull ${env.IMAGE_NAME}
                            
                            # 2. Garantir que a Base de Dados de Produção existe na VPS
                            if [ ! "\$(docker ps -q -f name=lcm-db-prod)" ]; then
                                echo "Criando base de dados de Produção..."
                                docker run -d --name lcm-db-prod \
                                  -e 'ACCEPT_EULA=Y' -e 'MSSQL_SA_PASSWORD=SenhaForteProd123!' \
                                  -p 1433:1433 --restart always \
                                  mcr.microsoft.com/mssql/server:2022-latest
                                sleep 20 # Espera o SQL Server arrancar
                            fi

                            # 3. Reiniciar a Aplicação ligando-a à BD local da VPS
                            docker stop lcm-app-prod || true
                            docker rm lcm-app-prod || true
                            docker run -d --name lcm-app-prod -p 8080:80 \
                                -e ConnectionStrings__DefaultConnection="Server=lcm-db-prod;Database=LCM_Prod;User Id=sa;Password=SenhaForteProd123!;TrustServerCertificate=True;" \
                                --link lcm-db-prod:lcm-db-prod \
                                --restart always ${env.IMAGE_NAME}
EOF
                    """
                }
            }
        }
    }

    post {
        success {
            mail to: "${env.TEAM_EMAILS}, ${env.CHIEFS_EMAILS}",
                 subject: "✅ SUCESSO: Aplicação Online na VPS",
                 body: "O deploy foi concluído com sucesso em https://lcmp.amover.pt/"
        }
    }
}
