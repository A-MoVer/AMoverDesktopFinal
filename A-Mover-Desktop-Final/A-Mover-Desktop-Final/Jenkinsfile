pipeline {
    agent none // Não define um agente global para podermos alternar entre Docker e Host

    environment {
        RECIPIENTS = "diogooresende@utad.pt, dianamc@utad.pt"
    }

    stages {
        stage('Checkout Código') {
            agent any
            steps {
                checkout scm
            }
        }

        // ==========================================
        // 🧪 PASSO 1: TESTES ISOLADOS NO CLUSTER
        // ==========================================
        stage('Executar Testes de Validação') {
            agent {
                docker {
                    image 'mcr.microsoft.com/dotnet/sdk:8.0'
                    // Garante que o container tem permissões para ler os ficheiros do workspace
                    args '-u root'
                }
            }
            steps {
                echo '🚀 A iniciar os testes automatizados dentro do contentor .NET 8...'
                
                // O comando "tee" grava o output no ficheiro test_result.log para enviarmos por email depois
                sh 'dotnet test A-Mover-Desktop-Final/A-Mover-Desktop-Final.sln --configuration Release 2>&1 | tee test_result.log'
            }
        }

        // ==========================================
        // 🚀 PASSO 2: DEPLOY EM PRE-PROD (SÓ SE PASSAR!)
        // ==========================================
        stage('Deploy to PRE-PROD') {
            agent any // Aqui o Jenkins usa a máquina infra01 para ter acesso ao kubectl
            steps {
                echo '✅ Todos os testes passaram! A atualizar o ambiente de Pre-Prod...'
                
                // Aplica os YAMLs que estão na tua pasta de pre-prod no infra01
                sh "kubectl apply -f /home/diogo_admin/lcm-k8s/preprod/ -n lcm-preprod"
                sh "kubectl rollout restart deployment/lcm-app-preprod-deployment -n lcm-preprod"
            }
        }
    }

    // ==========================================
    // 📢 NOTIFICAÇÕES COMPLETAS (REPORTING)
    // ==========================================
    post {
        success {
            echo '📧 A enviar email de sucesso...'
            mail to: "${env.RECIPIENTS}",
                 subject: "✅ Jenkins: Sucesso no Pipeline - Pre-Prod Atualizado",
                 body: """Olá Diogo e Diana,\n\n
O pipeline foi executado com sucesso e todos os testes automatizados passaram!\n
A nova versão já está disponível para validação em Pre-Produção.\n\n
🔗 Aceder ao ambiente: http://lcm-preprod.amover\n\n
Cumprimentos,\n
Servidor Jenkins (infra01)"""
        }
        
        failure {
            echo '📧 A recolher logs de erro para a Diana...'
            script {
                // Tenta ler o ficheiro de log gerado no passo de teste
                def fullLog = "Não foi possível recuperar o log detalhado dos testes."
                try {
                    if (fileExists('test_result.log')) {
                        fullLog = readFile('test_result.log')
                        // Se o log for demasiado grande, cortamos apenas os últimos 5000 caracteres
                        if (fullLog.length() > 5000) {
                            fullLog = " (Log truncado por tamanho)...\n" + fullLog.substring(fullLog.length() - 5000)
                        }
                    }
                } catch (Exception e) {
                    fullLog = "Erro ao ler o ficheiro de log: ${e.message}"
                }

                mail to: "${env.RECIPIENTS}",
                     subject: "❌ Jenkins: FALHA no Pipeline (Testes Recusados)",
                     body: """Olá Diana,\n\n
Os testes automatizados falharam e o deploy para Pre-Prod foi bloqueado por segurança.\n
Abaixo encontras o relatório detalhado do erro gerado pelo .NET SDK:\n\n
--------------------------------------------------
📋 RELATÓRIO DE ERRO (.NET TEST LOG):
--------------------------------------------------
${fullLog}
--------------------------------------------------\n\n
Por favor, verifica os erros acima, corrige-os localmente e faz um novo push.\n\n
Cumprimentos,\n
Servidor Jenkins (infra01)"""
            }
        }
    }
}
